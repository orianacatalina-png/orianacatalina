  <script>
window.addEventListener("DOMContentLoaded", () => {

const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        const decos = entry.target.querySelectorAll('.decoracion');

        if (entry.isIntersecting) {
            decos.forEach(d => d.classList.add('revelar'));
        } else {
            decos.forEach(d => d.classList.remove('revelar'));
        }
    });
}, { threshold: 0.5 });

observer.observe(document.querySelector(".tribales"));

});
</script>
